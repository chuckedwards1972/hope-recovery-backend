// POLR Restoration Network — Production Prisma Schema
// Multi-tenant, multi-campus ministry operating system

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  MEMBER
  GROUP_CHAIR
  CAMPUS_LEADER
  AMBASSADOR
  HQ_ADMIN
}

enum CampusLifecycle {
  PLANNING
  LAUNCHING
  ACTIVE
  SUSTAINABLE
  MULTIPLYING
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum DonationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum EventType {
  LOGIN
  LOGOUT
  MEETING_ATTEND
  LESSON_COMPLETE
  DONATION_MADE
  HOUSING_APPLY
  JOB_APPLY
  TESTIMONY_SUBMIT
  LEVEL_UP
  LEADERSHIP_ACTION
  ALERT_TRIGGERED
  RESUME_UPLOAD
  CERTIFICATION_EARNED
}

// ─────────────────────────────────────────────
// CAMPUSES
// ─────────────────────────────────────────────

model Campus {
  id              String          @id @default(uuid())
  name            String
  slug            String          @unique
  city            String?
  state           String?
  address         String?
  phone           String?
  email           String?
  lifecycleStage  CampusLifecycle @default(PLANNING)
  leaderId        String?
  sponsoringCampusId String?     // campus that sponsored this launch
  approvedBy      String?        // HQ admin who approved the launch
  zeffyLink       String?         // Zeffy donation URL for this campus
  donationPoolId  String?
  isSharedPool    Boolean         @default(true) // true = uses POLR_CORE pool
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Relations
  users           User[]
  meetings        Meeting[]
  donations       Donation[]
  donationPool    DonationPool?   @relation(fields: [donationPoolId], references: [id])
  jobs            Job[]
  housingListings HousingListing[]
  platformEvents  PlatformEvent[]
  auditLogs       AuditLog[]
  approvalWorkflows ApprovalWorkflow[]
  meetingPreps    MeetingPrepSubmission[]
  sustainabilityIndex CampusSustainabilityIndex?

  @@map("campuses")
}

// ─────────────────────────────────────────────
// USERS
// ─────────────────────────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String
  name          String
  role          Role       @default(MEMBER)
  level         Int        @default(5) // 0=HQ Admin, 1=Ambassador, 2=Chair, 3=Housemother, 4=Workforce, 5=Member, 6=Guest
  status        UserStatus @default(ACTIVE)
  campusId      String
  campus        Campus     @relation(fields: [campusId], references: [id])
  mentorId      String?
  phone         String?
  avatarUrl     String?
  bio           String?
  sobrietyDate         DateTime?
  joinedAt             DateTime   @default(now())
  lastLoginAt          DateTime?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  // Auth
  refreshTokens RefreshToken[]

  // Activity
  attendances       Attendance[]
  donations         Donation[]
  resumes           Resume[]
  jobApplications   JobApplication[]
  housingApplications HousingApplication[]
  testimonies       Testimony[]
  levelHistory      LevelHistory[]
  certifications    Certification[]
  platformEvents    PlatformEvent[]
  charedMeetings    Meeting[]       @relation("MeetingChair")
  auditActorLogs    AuditLog[]      @relation("AuditActor")
  workflowsRequested ApprovalWorkflow[] @relation("WorkflowRequester")
  workflowsApproved  ApprovalWorkflow[] @relation("WorkflowApprover")
  scoringHistory    ScoringHistory[]
  meetingPreps      MeetingPrepSubmission[]
  mediaItems        MediaItem[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────
// LEVEL PROGRESSION
// ─────────────────────────────────────────────

model LevelHistory {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromLevel  Int
  toLevel    Int
  reason     String?
  grantedBy  String?
  createdAt  DateTime @default(now())

  @@map("level_history")
}

model Certification {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String   // e.g. WORKFORCE, LEADERSHIP, PROGRAM_COMPLETION
  issuedBy    String?
  issuedAt    DateTime @default(now())
  expiresAt   DateTime?
  metadata    Json?

  @@map("certifications")
}

// ─────────────────────────────────────────────
// MEETINGS & ATTENDANCE
// ─────────────────────────────────────────────

model Meeting {
  id          String     @id @default(uuid())
  campusId    String
  campus      Campus     @relation(fields: [campusId], references: [id])
  chairId     String?
  chair       User?      @relation("MeetingChair", fields: [chairId], references: [id])
  title       String
  topic       String?
  location    String?
  meetingDate DateTime
  dayOfWeek   String?    // "Monday", "Wednesday", etc.
  timeOfDay   String?    // "7:00 PM"
  isRecurring Boolean    @default(false)
  isActive    Boolean    @default(true)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  attendances Attendance[]
  prepSubmissions MeetingPrepSubmission[]
}

model Attendance {
  id          String   @id @default(uuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  checkinTime DateTime @default(now())
  notes       String?

  @@unique([meetingId, userId])
  @@map("attendance")
}

// ─────────────────────────────────────────────
// DONATION SYSTEM (ZEFFY INTEGRATION)
// ─────────────────────────────────────────────

model DonationPool {
  id             String   @id @default(uuid())
  name           String
  zeffyLink      String
  isShared       Boolean  @default(false)
  isActive       Boolean  @default(true)
  targetAmount   Decimal? @db.Decimal(12, 2)
  currentBalance Decimal  @default(0) @db.Decimal(12, 2)
  createdAt      DateTime @default(now())

  campuses       Campus[]
  donations      Donation[]

  @@map("donation_pools")
}

model Donation {
  id                 String         @id @default(uuid())
  userId             String?
  user               User?          @relation(fields: [userId], references: [id])
  campusId           String
  campus             Campus         @relation(fields: [campusId], references: [id])
  poolId             String?
  pool               DonationPool?  @relation(fields: [poolId], references: [id])
  amount             Decimal        @db.Decimal(10, 2)
  campaign           String?
  zeffyReference     String?
  verificationStatus DonationStatus @default(PENDING)
  verifiedBy         String?
  verifiedAt         DateTime?
  donorName          String?        // for anonymous/non-member donors
  donorEmail         String?
  notes              String?
  createdAt          DateTime       @default(now())

  @@map("donations")
}

// ─────────────────────────────────────────────
// WORKFORCE MODULE
// ─────────────────────────────────────────────

model Resume {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileUrl       String   // S3/R2 URL
  fileKey       String   // storage key
  fileName      String?
  isActive      Boolean  @default(true)
  approved      Boolean  @default(false)
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime @default(now())

  @@map("resumes")
}

model Job {
  id           String   @id @default(uuid())
  campusId     String
  campus       Campus   @relation(fields: [campusId], references: [id])
  employerName String
  title        String
  description  String?
  location     String?
  payRange     String?
  requirements String?
  isActive     Boolean  @default(true)
  closesAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applications JobApplication[]

  @@map("jobs")
}

model JobApplication {
  id          String            @id @default(uuid())
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  status      ApplicationStatus @default(SUBMITTED)
  coverNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([jobId, userId])
  @@map("job_applications")
}

// ─────────────────────────────────────────────
// HOUSING MODULE
// ─────────────────────────────────────────────

model HousingListing {
  id               String   @id @default(uuid())
  campusId         String
  campus           Campus   @relation(fields: [campusId], references: [id])
  partnerName      String
  address          String?
  city             String?
  state            String?
  capacity         Int      @default(1)
  occupied         Int      @default(0)
  housingType      String?
  description      String?
  requirements     String?
  requiresSobriety Boolean  @default(false)
  monthlyRent      Decimal? @db.Decimal(10, 2)
  contactEmail     String?
  contactPhone     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  applications HousingApplication[]

  @@map("housing_listings")
}

model HousingApplication {
  id          String            @id @default(uuid())
  listingId   String
  listing     HousingListing    @relation(fields: [listingId], references: [id])
  userId      String
  user        User              @relation(fields: [userId], references: [id])
  status      ApplicationStatus @default(SUBMITTED)
  moveInDate  DateTime?
  moveOutDate DateTime?
  notes       String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("housing_applications")
}

// ─────────────────────────────────────────────
// TESTIMONIES
// ─────────────────────────────────────────────

model Testimony {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  content     String
  isPublic    Boolean  @default(false)
  isAnonymous Boolean  @default(false)
  mediaUrl    String?
  approved    Boolean  @default(false)
  approvedBy  String?
  createdAt   DateTime @default(now())

  @@map("testimonies")
}

// ─────────────────────────────────────────────
// AI EVENT LOG — The brain
// ─────────────────────────────────────────────

model PlatformEvent {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  campusId  String
  campus    Campus    @relation(fields: [campusId], references: [id])
  eventType EventType
  metadata  Json?     // flexible payload per event type
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([campusId, eventType])
  @@index([createdAt])
  @@map("platform_events")
}

// ─────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String
  actor      User     @relation("AuditActor", fields: [actorId], references: [id])
  campusId   String?
  campus     Campus?  @relation(fields: [campusId], references: [id])
  action     String
  targetType String?  // "User", "Meeting", "Donation", etc.
  targetId   String?
  diff       Json?    // before/after state
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ═══════════════════════════════════════════
// PHASE 2 ADDITIONS — Governance + Intelligence
// ═══════════════════════════════════════════

// ─── APPROVAL WORKFLOW ENGINE ────────────────
model ApprovalWorkflow {
  id           String         @id @default(uuid())
  type         String         // WorkflowType enum value
  status       String         @default("PENDING") // WorkflowStatus
  requesterId  String
  requester    User           @relation("WorkflowRequester", fields: [requesterId], references: [id])
  approverId   String?
  approver     User?          @relation("WorkflowApprover", fields: [approverId], references: [id])
  campusId     String
  campus       Campus         @relation(fields: [campusId], references: [id])
  targetId     String?
  targetType   String?
  notes        String?
  approverNote String?
  metadata     Json?
  resolvedAt   DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([campusId, status])
  @@index([requesterId])
  @@map("approval_workflows")
}

// ─── SCORING HISTORY ─────────────────────────
model ScoringHistory {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  engagementScore Int      @default(0)
  relapseRisk     Int      @default(0)
  relapseLevel    String   @default("LOW")
  leadershipScore Int      @default(0)
  leadershipReady Boolean  @default(false)
  certProgress    Int      @default(0)
  triggeredBy     String?
  computedAt      DateTime @default(now())

  @@index([userId, computedAt])
  @@map("scoring_history")
}

// ─── MEETING PREP SUBMISSIONS ────────────────
model MeetingPrepSubmission {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  meetingId           String
  meeting             Meeting  @relation(fields: [meetingId], references: [id])
  campusId            String
  campus              Campus   @relation(fields: [campusId], references: [id])
  identityDeclared    Boolean  @default(false)
  stepReflection      String?
  scriptureInsight    String?
  meetingFocus        String?
  sessionReflection   String?
  createdAt           DateTime @default(now())

  @@map("meeting_prep_submissions")
}

// ─── MEDIA (PODCAST / VLOG) ──────────────────
model MediaItem {
  id           String    @id @default(uuid())
  type         String    // PODCAST, VLOG, TEACHING, ANNOUNCEMENT
  status       String    @default("DRAFT")
  title        String
  description  String?
  fileUrl      String?
  fileKey      String?
  thumbnailUrl String?
  duration     Int?      // seconds
  tags         String[]
  campusId     String?   // null = all campuses (HQ broadcast)
  authorId     String
  author       User      @relation(fields: [authorId], references: [id])
  publishedAt  DateTime?
  approvedBy   String?
  plays        Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, type])
  @@map("media_items")
}

// ─── CAMPUS SUSTAINABILITY INDEX ─────────────
model CampusSustainabilityIndex {
  id                   String   @id @default(uuid())
  campusId             String   @unique
  campus               Campus   @relation(fields: [campusId], references: [id])
  attendanceScore      Int      @default(0)
  donorScore           Int      @default(0)
  housingScore         Int      @default(0)
  workforceScore       Int      @default(0)
  leadershipScore      Int      @default(0)
  totalScore           Int      @default(0)
  recommendedLifecycle String?
  computedAt           DateTime @default(now())

  @@map("campus_sustainability_index")
}
