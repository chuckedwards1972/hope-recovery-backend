# ══════════════════════════════════════════════
# POLR PLATFORM v5 — Environment Configuration
# Copy to .env and fill in all values marked (REQUIRED)
# ══════════════════════════════════════════════

# ─── App ───────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_VERSION=5.0.0
LOG_LEVEL=info
ENABLE_CRONS=false          # Set true in production

# ─── Database (REQUIRED) ───────────────────────
DATABASE_URL="postgresql://polr:YOUR_PASSWORD@localhost:5432/polr_development"
# Production: postgresql://polr:STRONG_PASSWORD@db:5432/polr_production

# ─── JWT Secrets (REQUIRED — generate strong random strings) ──
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_HEX
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_64_CHAR_RANDOM_HEX
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── CORS ──────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# Production: https://your-domain.com

# ─── Redis (optional — caching, remove if not using) ──
# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:PASSWORD@redis:6379   # with auth

# ─── Email Provider (choose one) ───────────────
EMAIL_PROVIDER=console    # 'console' | 'resend'
EMAIL_FROM=POLR Platform <noreply@polris4life.com>

# Option 1: Resend (recommended — free tier, no credit card)
# Sign up: https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── AI Provider (choose one) ──────────────────
# Option 1: Groq — FREE, fast, Llama 3 70B (RECOMMENDED)
# Sign up: https://console.groq.com — 30 seconds, no payment
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama3-70b-8192

# Option 2: Ollama — 100% local, zero cost, zero internet
# Install: https://ollama.ai then: ollama pull llama3
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# Option 3: Together AI — free $25 credit
# Sign up: https://api.together.xyz
# TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TOGETHER_MODEL=meta-llama/Llama-3-70b-chat-hf

# Option 4: Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# If none configured → graceful fallback (scripture-based static responses)

# ─── File Storage (optional) ───────────────────
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET_NAME=polr-files
# Or use Cloudflare R2 (S3-compatible, free tier):
# AWS_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# ─── Zeffy Donation Links ──────────────────────
ZEFFY_POLR_CORE_LINK=https://www.zeffy.com/en-US/donation-form/polr-core
ZEFFY_PORT_ALLEN_LINK=https://www.zeffy.com/en-US/donation-form/polr-port-allen
# Each campus can have its own link — set in Campus record via admin panel

# ─── Sentry (optional — error tracking) ────────
# SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ─── Production checklist ──────────────────────
# [ ] DATABASE_URL points to production PostgreSQL
# [ ] JWT secrets are 64+ char random hex (NOT the defaults above)
# [ ] CORS_ORIGIN matches your deployed frontend URL
# [ ] EMAIL_PROVIDER=resend with valid RESEND_API_KEY
# [ ] At least one AI provider key set (Groq recommended)
# [ ] ENABLE_CRONS=true
# [ ] NODE_ENV=production
# [ ] Run: npx prisma migrate deploy
# [ ] Run: npx prisma db seed
